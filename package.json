{
	"name": "jgrep",
	"version": "0.1.0",
	"description": "A lightweight semantic code-search tool using Voyage AI embeddings",
	"type": "module",
	"bin": {
		"jgrep": "dist/cli.js"
	},
	"scripts": {
		"build": "tsup src/cli.ts --format esm --clean",
		"dev": "tsup src/cli.ts --format esm --watch",
		"lint": "eslint src",
		"format": "prettier --write ."
	},
	"engines": {
		"node": ">=18"
	},
	"dependencies": {
		"@lancedb/lancedb": "^0.16.0",
		"commander": "^12.0.0",
		"voyageai": "^0.0.4",
		"globby": "^14.0.0",
		"ignore": "^5.3.0",
		"picocolors": "^1.0.0"
	},
	"devDependencies": {
		"typescript": "^5.4.0",
		"tsup": "^8.0.0",
		"@types/node": "^20.0.0",
		"eslint": "^8.57.1",
		"@typescript-eslint/parser": "^7.0.0",
		"@typescript-eslint/eslint-plugin": "^7.0.0",
		"prettier": "^3.2.0"
	}
}
